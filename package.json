{
  "name": "arkane",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A locally encrypted PWA vault synced only through a private GitHub repository.",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build && node scripts/verify-build.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "check": "npm run test && npm run build"
  },
  "dependencies": {
    "charter-webfont": "^4.1.0",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.22",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^8.0.14",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.7"
  }
}
